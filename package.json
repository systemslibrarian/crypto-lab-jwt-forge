{
  "name": "crypto-lab-jwt-forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A JWT/JWS security playground: alg:none and key-confusion attacks, with a Correct vs Vulnerable verifier contrast.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
